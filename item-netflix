<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Signal & The Noise | Leadership Sim</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --netflix-red: #E50914;
            --apple-dark-bg: #000000;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--apple-dark-bg);
            color: #F5F5F7; 
            overscroll-behavior: none;
            -webkit-font-smoothing: antialiased;
        }

        .text-netflix { color: var(--netflix-red); }
        .bg-netflix { background-color: var(--netflix-red); }

        .glass-panel {
            background: rgba(28, 28, 30, 0.7);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        }

        .glass-bar {
            background: linear-gradient(to top, rgba(0,0,0,0.95) 20%, rgba(0,0,0,0.8) 70%, transparent);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .fade-in-up {
            animation: fadeInUp 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            opacity: 0;
            transform: translateY(10px);
        }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }

        .character-img {
            filter: grayscale(20%) brightness(0.9);
            object-fit: cover;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.4); }
        
        .apple-btn {
            transition: all 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .apple-btn:active:not(:disabled) { transform: scale(0.97); }
        .apple-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* Chat Specific Styles */
        .chat-bubble {
            max-width: 85%;
            word-wrap: break-word;
            animation: chatPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            transform-origin: bottom left;
            opacity: 0;
            transform: scale(0.9);
        }
        .chat-bubble.user {
            transform-origin: bottom right;
        }

        @keyframes chatPop {
            to { opacity: 1; transform: scale(1); }
        }

        .typing-indicator span {
            display: inline-block;
            width: 5px;
            height: 5px;
            background-color: #888;
            border-radius: 50%;
            margin: 0 2px;
            animation: bounce 1.4s infinite ease-in-out both;
        }
        .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
        .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
        
        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        @keyframes breathe {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.5); opacity: 0.7; }
        }

        .glow-breathe {
            position: absolute;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, rgba(229,9,20,0.8) 0%, rgba(0,0,0,0) 70%);
            animation: breathe 4s ease-in-out infinite;
            z-index: 0;
            border-radius: 50%;
        }

        .readable-role {
            font-size: 0.85rem;
            letter-spacing: 0.05em;
            font-weight: 600;
        }
        
        /* Highlight for System Prompts */
        .system-prompt-bg {
            background: linear-gradient(135deg, rgba(28,28,30,0.9) 0%, rgba(44,44,46,0.9) 100%);
            border: 1px solid rgba(255,255,255,0.2);
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center selection:bg-netflix-red selection:text-white">

    <!-- Loading Screen -->
    <div id="screen-loading" class="fixed inset-0 z-50 bg-black flex flex-col items-center justify-center space-y-10 transition-opacity duration-700">
        <div class="relative flex items-center justify-center">
            <div class="glow-breathe"></div>
            <!-- Stylized 'N' Logo -->
            <svg viewBox="0 0 64 84" class="w-20 md:w-28 relative z-10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 0h19v84H0z" fill="#B20710"/>
                <path d="M45 0h19v84H45z" fill="#B20710"/>
                <path d="M0 0h20l44 84H44z" fill="#E50914" style="filter: drop-shadow(-6px 0px 8px rgba(0,0,0,0.6));"/>
            </svg>
        </div>
        <div class="w-64 h-[4px] bg-white/10 rounded-full overflow-hidden relative z-10">
            <div id="loading-bar" class="h-full bg-netflix w-0 transition-all duration-700 ease-out"></div>
        </div>
        <p id="loading-text" class="text-base font-semibold text-gray-300 uppercase tracking-widest animate-pulse relative z-10">Initializing Comm Channel...</p>
    </div>

    <!-- Main Menu -->
    <div id="screen-start" class="hidden w-full max-w-6xl p-6 fade-in-up text-center space-y-12 py-24">
        <div class="space-y-6">
            <h1 class="text-6xl md:text-8xl font-bold tracking-tighter">
                The <span class="text-netflix">Signal</span> <br>and the Noise.
            </h1>
            <p class="text-xl md:text-2xl text-gray-300 font-light max-w-2xl mx-auto tracking-tight">
                A conversational product leadership simulation.
            </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto text-left mt-16 mb-16">
            <div class="glass-panel p-8 rounded-3xl">
                <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center mb-6">
                    <i data-lucide="target" class="w-6 h-6 text-netflix"></i>
                </div>
                <h3 class="font-semibold text-xl mb-3 tracking-tight text-white">The Scenario</h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                    You were just hired as the new Product Lead for Project Nova, a high-ticket B2B SaaS platform for Marketing Operations. In your first week, the beta dashboard starts bleeding users during the "Advanced Configuration" onboarding step. Your veteran Head of Data (Sarah) and Lead UX Designer (Marcus) are clashing over how to fix it in a live Slack channel.
                </p>
            </div>
            <div class="glass-panel p-8 rounded-3xl">
                <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center mb-6">
                    <i data-lucide="brain-circuit" class="w-6 h-6 text-netflix"></i>
                </div>
                <h3 class="font-semibold text-xl mb-3 tracking-tight text-white">Learning Objectives</h3>
                <ul class="text-sm text-gray-400 space-y-2">
                    <li>• <b>Analyze</b> conflicting qualitative and quantitative raw data to find root causes. <i class="text-xs text-gray-500">(Bloom's L4)</i></li>
                    <li>• <b>Evaluate</b> the second-order business risks of proposed directives. <i class="text-xs text-gray-500">(Bloom's L5)</i></li>
                    <li>• <b>Apply</b> psychological safety principles to mediate team conflict as a new leader. <i class="text-xs text-gray-500">(Bloom's L3)</i></li>
                </ul>
            </div>
        </div>

        <button onclick="startGame()" class="apple-btn bg-white text-black px-12 py-4 rounded-full font-bold text-lg hover:bg-gray-200 shadow-[0_0_40px_rgba(255,255,255,0.1)] focus:outline-none">
            Join Team Channel
        </button>
    </div>

    <!-- Game UI (Chat Interface) -->
    <div id="screen-play" class="hidden w-full h-screen flex flex-col md:flex-row overflow-hidden">
        
        <!-- Left Panel: Context & Dashboard -->
        <div class="w-full md:w-[350px] bg-[#0A0A0A] border-r border-white/10 p-6 flex flex-col z-20 shrink-0 shadow-2xl">
            <div class="flex justify-between items-center mb-8">
                <div class="text-xs uppercase tracking-[0.15em] text-gray-400 font-bold flex items-center">
                    <div class="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></div>
                    # proj-nova-crisis
                </div>
            </div>

            <!-- Dashboard Stats -->
            <div class="space-y-4 mb-8">
                <div class="glass-panel p-4 rounded-2xl border border-white/5">
                    <div class="flex justify-between items-end mb-2">
                        <span class="text-[10px] uppercase tracking-widest text-gray-500">Team Safety</span>
                        <span id="trust-text" class="text-sm font-bold text-white">60%</span>
                    </div>
                    <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                        <div id="trust-bar" class="h-full bg-emerald-500 transition-all duration-700 ease-out" style="width: 60%;"></div>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex flex-col space-y-8">
                <div class="text-xs uppercase tracking-[0.15em] text-gray-400 font-bold mb-2 border-b border-white/10 pb-3">Channel Members</div>
                
                <div class="flex items-center space-x-4">
                    <img id="sidebar-sarah" class="w-12 h-12 rounded-full border border-blue-500/30 character-img" src="" alt="Sarah">
                    <div>
                        <h3 class="font-bold text-base text-white">Sarah Jenkins</h3>
                        <p class="readable-role text-blue-300 mt-0.5">Product Data</p>
                    </div>
                </div>

                <div class="flex items-center space-x-4">
                    <img id="sidebar-marcus" class="w-12 h-12 rounded-full border border-yellow-500/30 character-img" src="" alt="Marcus">
                    <div>
                        <h3 class="font-bold text-base text-white">Marcus Vance</h3>
                        <p class="readable-role text-yellow-300 mt-0.5">Lead UX</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: Chat Stream -->
        <div class="flex-1 relative flex flex-col h-full bg-[#050505]">
            
            <!-- Chat History -->
            <div id="chat-container" class="flex-1 overflow-y-auto p-4 md:p-8 space-y-6 pb-[300px]">
                <!-- Chat Bubbles injected here -->
            </div>

            <!-- Quick Replies (Interaction Area) -->
            <div id="interaction-area" class="absolute bottom-0 left-0 right-0 p-4 md:p-6 glass-bar z-30 border-t border-white/5">
                <div class="max-w-3xl mx-auto w-full">
                    
                    <!-- Dynamic Choices List -->
                    <div id="choices-list" class="flex flex-col space-y-3">
                        <!-- Reply buttons injected here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- API SETUP ---
        const apiKey = ""; 
        let imgSarahUrl = "";
        let imgMarcusUrl = "";
        
        async function fetchImageWithRetry(prompt, retries = 2) {
            if (!apiKey) return null; 
            const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;
            const payload = { instances: { prompt: prompt }, parameters: { sampleCount: 1 } };
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    const data = await response.json();
                    if (data.predictions && data.predictions[0] && data.predictions[0].bytesBase64Encoded) {
                        return `data:image/png;base64,${data.predictions[0].bytesBase64Encoded}`;
                    } else throw new Error("Invalid format");
                } catch (error) {
                    if (i === retries - 1) return null; 
                    await new Promise(r => setTimeout(r, 1000));
                }
            }
        }

        async function initializeApp() {
            lucide.createIcons();
            const loadingBar = document.getElementById('loading-bar');
            
            const sarahPrompt = "A cinematic, dramatic corporate headshot of a highly intelligent female tech product manager in a modern, minimalist glass office. Bright, high contrast, moody, sharp focus, hyper-realistic.";
            const marcusPrompt = "A cinematic, moody portrait of a passionate male Lead UX Designer wearing a stylish dark shirt in a design studio. Warm ambient lighting. Ultra premium, sharp focus, realistic.";

            loadingBar.style.width = "40%";
            imgSarahUrl = await fetchImageWithRetry(sarahPrompt) || 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=150&h=150';
            
            loadingBar.style.width = "80%";
            imgMarcusUrl = await fetchImageWithRetry(marcusPrompt) || 'https://images.unsplash.com/photo-1556157382-97eda2d62296?auto=format&fit=crop&q=80&w=150&h=150';

            document.getElementById('sidebar-sarah').src = imgSarahUrl;
            document.getElementById('sidebar-marcus').src = imgMarcusUrl;

            loadingBar.style.width = "100%";
            
            setTimeout(() => {
                document.getElementById('screen-loading').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('screen-loading').classList.add('hidden');
                    document.getElementById('screen-start').classList.remove('hidden');
                }, 700);
            }, 600);
        }

        // --- GAME STATE & SCRIPT ---
        const state = { 
            trust: 60, 
            evidenceGathered: [], 
            ambiguityHeld: false,
            scaffoldScore: 0,
            pendingDecision: null // Holds the final decision during the risk assessment
        };

        const SCRIPT = {
            intro: [
                { sender: 'system', text: 'Channel #proj-nova-crisis created. You (New Product Lead), Sarah, and Marcus joined.', delay: 500 },
                { sender: 'sarah', text: 'Welcome to the team. Wish the circumstances were better. The beta onboarding metrics for Project Nova are in. We have a massive leak.', delay: 1500 },
                { sender: 'sarah', text: 'When users reach the "Advanced Configuration" step—where they link their internal databases—we are seeing a 65% drop-off. The signal is clear: users are experiencing cognitive overload.', delay: 2000 },
                { sender: 'sarah', text: 'We need to cut this complex step entirely and default them straight into the basic dashboard to save our Q3 activation targets.', delay: 2000 },
                { sender: 'marcus', text: 'Hold on. That configuration step is where the user customizes the platform to their specific enterprise workflow. It is the core value prop of our highest tier!', delay: 2500 },
                { sender: 'marcus', text: 'If we cut it, the tool feels generic and they will churn later. Your data is missing the "why".', delay: 2000 },
                { sender: 'action', type: 'choices_intro' }
            ],
            
            // LOGS INVESTIGATION (SCAFFOLDING PHASE)
            gather1: [
                { sender: 'user', text: '@Sarah pull the FullStory session recordings for the drop-off step. Let\'s look at the raw tape.', delay: 500 },
                { sender: 'system', text: 'Fetching recordings...', delay: 1500 },
                { sender: 'sarah', text: 'I\'m watching the replays now. They aren\'t exhibiting "overload" behaviors like erratic mouse movements or idle scrolling.', delay: 2000 },
                { sender: 'sarah', text: 'Instead, they are hovering over three labels: "LDAP Binding", "SSO Provisioning", and "Webhooks". They click them repeatedly, pause for 30 seconds, and then close the tab.', delay: 2500 },
                { sender: 'system_prompt', text: 'SCAFFOLDING OPPORTUNITY: Help your team interpret this specific user behavior pattern.', delay: 1000 },
                { sender: 'action', type: 'scaffold_logs' }
            ],
            logs_correct: [
                { sender: 'user', text: 'They are hovering and clicking specific technical terms, then pausing. They are looking for tooltips or help text. It\'s a vocabulary mismatch.', delay: 500 },
                { sender: 'marcus', text: 'Wait... you\'re right. Our target beta users are Marketing Ops, not IT. They don\'t know what "LDAP" means. It\'s a translation issue.', delay: 2000 },
                { sender: 'sarah', text: 'That makes sense. They aren\'t overwhelmed by options, they just feel stupid because they don\'t know the acronyms.', delay: 2000 },
                { sender: 'action', type: 'choices_post_gather' }
            ],
            logs_incorrect_bug: [
                { sender: 'user', text: 'Rage-clicking means the buttons are broken. We need to file a critical bug report with engineering immediately.', delay: 500 },
                { sender: 'marcus', text: 'Actually, those aren\'t buttons. They are just text labels for the form fields. They aren\'t meant to be clickable.', delay: 2000 },
                { sender: 'sarah', text: 'Exactly. Which means they are clicking them out of frustration because they don\'t understand what the fields are asking for. It\'s a vocabulary issue.', delay: 2500 },
                { sender: 'action', type: 'choices_post_gather' }
            ],
            logs_incorrect_overload: [
                { sender: 'user', text: 'They are pausing and giving up. It\'s too much information at once. Sarah is right, it\'s cognitive overload.', delay: 500 },
                { sender: 'sarah', text: 'Actually, looking closer... if it was overload, wouldn\'t they scroll around looking for an exit? They are fixated specifically on those three words.', delay: 2000 },
                { sender: 'marcus', text: 'Sarah\'s right. They are stuck on the terminology. Our users are Marketing Ops, not IT. We need to translate "LDAP" into human terms.', delay: 2500 },
                { sender: 'action', type: 'choices_post_gather' }
            ],

            // BENCHMARKS INVESTIGATION (SCAFFOLDING PHASE)
            gather2: [
                { sender: 'user', text: '@Sarah pull competitor B2B onboarding benchmarks. Let\'s see industry standards.', delay: 500 },
                { sender: 'system', text: 'Aggregating industry data...', delay: 1500 },
                { sender: 'sarah', text: 'Benchmarks pulled. High-friction onboarding is actually standard for enterprise tools. A 60% drop-off is roughly the 50th percentile.', delay: 2000 },
                { sender: 'marcus', text: 'And look at the LTV! Competitors show that users who complete complex setups have a 90% higher lifetime value.', delay: 2000 },
                { sender: 'system_prompt', text: 'SCAFFOLDING OPPORTUNITY: How should the team view "friction" in this context?', delay: 1000 },
                { sender: 'action', type: 'scaffold_benchmarks' }
            ],
            benchmarks_correct: [
                { sender: 'user', text: 'Look at the LTV. In B2B Enterprise, friction isn\'t always bad. It acts as a filter, ensuring high-intent buyers get a deeply customized experience.', delay: 500 },
                { sender: 'sarah', text: 'I see your point. We shouldn\'t optimize for pure volume if it sacrifices the quality of the activated user.', delay: 2000 },
                { sender: 'action', type: 'choices_post_gather' }
            ],
            benchmarks_incorrect: [
                { sender: 'user', text: 'Even if it\'s standard, 65% is too high. Our primary goal right now is top-of-funnel activation volume.', delay: 500 },
                { sender: 'marcus', text: 'Optimizing for volume over value is how you build a generic product that no one loves. But you\'re the boss.', delay: 2000 },
                { sender: 'action', type: 'choices_post_gather' }
            ],

            // DECISION PHASE
            decision_prompt: [
                { sender: 'system', text: 'Final Decision Required. Executive review in 15 mins.', delay: 1000 },
                { sender: 'action', type: 'choices_decision' }
            ]
        };

        const OUTCOMES = {
            BAD_DATA: {
                title: "The Churn Trap", color: "text-red-400", bg: "bg-red-500/10", border: "border-red-500/30", trust: -30,
                text: "You forced Sarah's data edit. Short-term activation metrics looked great for Q3, but 3-month churn skyrocketed because users never learned how to leverage the tool's true power. Marcus feels his UX expertise was ignored.",
                debrief: "You assumed quantitative data answers the 'Why', but it only answers the 'What'. By cutting the feature to hit short-term targets, you sacrificed long-term product value and crushed team safety."
            },
            BAD_CREATIVE: {
                title: "The Friction Fire", color: "text-yellow-400", bg: "bg-yellow-500/10", border: "border-yellow-500/30", trust: -15,
                text: "You ignored the data and kept Marcus's step. Drop-off remained at 65%. The company missed its Q3 activation targets. Sarah's data team feels their quantitative insights are viewed as 'performative'.",
                debrief: "Creative disagreement is healthy, but ignoring glaring quantitative warning signs is a process failure. You protected the design intent but eroded the data team's psychological safety."
            },
            GOOD_PATH: {
                title: "The Safe Middle", color: "text-blue-400", bg: "bg-blue-500/10", border: "border-blue-500/30", trust: +10,
                text: "You compromised and added a 'Skip' button. It stopped the bleeding on activation metrics, and power users could still configure their workspace. However, the user base is now fragmented.",
                debrief: "You managed the tension and shipped a workable solution. But a compromise often leaves both sides slightly dissatisfied. True leadership is about finding the underlying truth, not just finding the middle."
            },
            BEST_PATH: {
                title: "Signal Master", color: "text-emerald-400", bg: "bg-emerald-500/10", border: "border-emerald-500/30", trust: +40,
                text: "By reframing the data, you discovered the real problem wasn't complexity, but clarity. Marcus rewrote the technical tooltips, Sarah validated the new retention curve, and drop-off plummeted.",
                debrief: "You recognized that data was answering the wrong question. You scaffolded the team to investigate the 'Why', and turned a destructive conflict into a creative collaboration. Masterful."
            }
        };

        // --- CHAT ENGINE ---
        let chatQueue = [];
        let isProcessing = false;

        function updateHUD() {
            const trustBar = document.getElementById('trust-bar');
            trustBar.style.width = `${state.trust}%`;
            document.getElementById('trust-text').innerText = `${state.trust}%`;
            if (state.trust < 40) trustBar.className = "h-full bg-red-500 transition-all duration-700 ease-out";
            else if (state.trust < 70) trustBar.className = "h-full bg-yellow-500 transition-all duration-700 ease-out";
            else trustBar.className = "h-full bg-emerald-500 transition-all duration-700 ease-out";
        }

        function startGame() {
            document.getElementById('screen-start').classList.add('hidden');
            document.getElementById('screen-play').classList.remove('hidden');
            state.trust = 60; state.evidenceGathered = []; state.ambiguityHeld = false; state.scaffoldScore = 0;
            updateHUD();
            queueScenario('intro');
        }

        function queueScenario(scenarioKey) {
            chatQueue = chatQueue.concat(SCRIPT[scenarioKey]);
            if (!isProcessing) processChatQueue();
        }

        async function processChatQueue() {
            if (chatQueue.length === 0) {
                isProcessing = false;
                return;
            }
            isProcessing = true;
            const msg = chatQueue.shift();

            if (msg.sender === 'action') {
                renderChoices(msg.type);
                isProcessing = false;
                return;
            }

            if (msg.sender === 'sarah' || msg.sender === 'marcus') {
                const typingId = showTypingIndicator(msg.sender);
                scrollToBottom();
                await new Promise(r => setTimeout(r, msg.delay));
                document.getElementById(typingId).remove();
            } else {
                await new Promise(r => setTimeout(r, msg.delay));
            }

            renderBubble(msg.sender, msg.text);
            scrollToBottom();
            processChatQueue();
        }

        function renderBubble(sender, text) {
            const container = document.getElementById('chat-container');
            const wrapper = document.createElement('div');
            
            if (sender === 'system') {
                wrapper.className = "flex justify-center fade-in-up my-6";
                wrapper.innerHTML = `<span class="bg-[#1C1C1E] border border-white/10 text-gray-400 text-[10px] uppercase tracking-[0.2em] px-5 py-2 rounded-full shadow-sm font-semibold">${text}</span>`;
            } else if (sender === 'system_prompt') {
                wrapper.className = "flex justify-center fade-in-up my-4 w-full";
                wrapper.innerHTML = `<div class="system-prompt-bg text-gray-200 text-sm px-6 py-4 rounded-2xl shadow-xl font-medium w-full text-center border-t-2 border-t-netflix"><i data-lucide="brain-circuit" class="w-5 h-5 inline text-netflix mr-2 mb-1"></i> ${text}</div>`;
            } else if (sender === 'user') {
                wrapper.className = "flex justify-end fade-in-up my-2";
                wrapper.innerHTML = `<div class="bg-[#2C2C2E] text-white text-base p-5 rounded-3xl rounded-tr-md chat-bubble user border border-white/10 shadow-md">${text}</div>`;
            } else {
                wrapper.className = "flex space-x-4 fade-in-up my-2";
                const isSarah = sender === 'sarah';
                const imgSrc = isSarah ? imgSarahUrl : imgMarcusUrl;
                const bubbleColor = isSarah ? 'bg-blue-900/20 border-blue-500/20 text-blue-50' : 'bg-yellow-900/20 border-yellow-500/20 text-yellow-50';
                const nameColor = isSarah ? 'text-blue-400' : 'text-yellow-400';
                const name = isSarah ? 'Sarah' : 'Marcus';

                wrapper.innerHTML = `
                    <img src="${imgSrc}" class="w-10 h-10 rounded-full border border-white/20 shrink-0 mt-1 object-cover shadow-sm">
                    <div class="flex flex-col items-start">
                        <span class="text-[11px] ${nameColor} font-bold mb-1.5 ml-2 uppercase tracking-wide">${name}</span>
                        <div class="${bubbleColor} border text-base p-5 rounded-3xl rounded-tl-md chat-bubble shadow-md leading-relaxed">${text}</div>
                    </div>
                `;
            }
            container.appendChild(wrapper);
            lucide.createIcons();
        }

        function showTypingIndicator(sender) {
            const container = document.getElementById('chat-container');
            const wrapper = document.createElement('div');
            const id = 'typing-' + Date.now();
            wrapper.id = id;
            wrapper.className = "flex space-x-3 fade-in-up";
            
            const isSarah = sender === 'sarah';
            const imgSrc = isSarah ? imgSarahUrl : imgMarcusUrl;
            
            wrapper.innerHTML = `
                <img src="${imgSrc}" class="w-10 h-10 rounded-full border border-white/20 shrink-0 mt-1 object-cover opacity-60 shadow-sm">
                <div class="bg-[#2C2C2E] border border-white/10 p-5 rounded-3xl rounded-tl-md flex items-center justify-center typing-indicator h-12 shadow-md">
                    <span></span><span></span><span></span>
                </div>
            `;
            container.appendChild(wrapper);
            return id;
        }

        function scrollToBottom() {
            const c = document.getElementById('chat-container');
            c.scrollTo({ top: c.scrollHeight, behavior: 'smooth' });
        }

        function renderChoices(type) {
            const choicesList = document.getElementById('choices-list');
            choicesList.innerHTML = '';
            
            let options = [];
            
            if (type === 'choices_intro' || type === 'choices_post_gather') {
                if (!state.evidenceGathered.includes('gather1')) {
                    options.push({ text: "Review Session Logs", cost: "Gather Context", icon: "video", action: () => { state.evidenceGathered.push('gather1'); state.ambiguityHeld = true; updateHUD(); document.getElementById('choices-list').innerHTML=''; queueScenario('gather1'); }});
                }
                if (!state.evidenceGathered.includes('gather2')) {
                    options.push({ text: "Review Competitor Benchmarks", cost: "Gather Context", icon: "bar-chart", action: () => { state.evidenceGathered.push('gather2'); state.ambiguityHeld = true; updateHUD(); document.getElementById('choices-list').innerHTML=''; queueScenario('gather2'); }});
                }
                options.push({ text: "Make Definitive Decision", cost: "Proceed", highlight: true, icon: "gavel", action: () => { document.getElementById('choices-list').innerHTML=''; queueScenario('decision_prompt'); }});
            
            } else if (type === 'scaffold_logs') {
                // Critical Thinking Question 1 - Enhanced Plausible Wrongs
                options = [
                    { text: "Rage-clicking means the buttons are broken. File a bug.", sub: "Assume Technical Issue", action: () => { document.getElementById('choices-list').innerHTML=''; queueScenario('logs_incorrect_bug'); }},
                    { text: "They are pausing and giving up. It's cognitive overload.", sub: "Agree with Original Data Bias", action: () => { document.getElementById('choices-list').innerHTML=''; queueScenario('logs_incorrect_overload'); }},
                    { text: "They are clicking technical terms looking for help. It's vocabulary.", sub: "Identify True Root Cause", highlight: true, action: () => { state.scaffoldScore++; document.getElementById('choices-list').innerHTML=''; queueScenario('logs_correct'); }}
                ];
            } else if (type === 'scaffold_benchmarks') {
                // Critical Thinking Question 2
                options = [
                    { text: "65% drop-off is still too high. We must optimize for volume.", sub: "Prioritize Top-of-Funnel", action: () => { document.getElementById('choices-list').innerHTML=''; queueScenario('benchmarks_incorrect'); }},
                    { text: "The friction acts as a filter. It ensures high LTV buyers.", sub: "Understand Business Model", highlight: true, action: () => { state.scaffoldScore++; document.getElementById('choices-list').innerHTML=''; queueScenario('benchmarks_correct'); }}
                ];
            } else if (type === 'choices_decision') {
                // Final Decision
                options = [
                    { text: "Cut the configuration step.", sub: "Side with Sarah", result: 'BAD_DATA' },
                    { text: "Keep the step as-is.", sub: "Side with Marcus", result: 'BAD_CREATIVE' },
                    { text: "Compromise: Add 'Skip Setup' button.", sub: "Middle Ground", result: 'GOOD_PATH' }
                ];
                if (state.evidenceGathered.includes('gather1') && state.scaffoldScore > 0) {
                    options.push({ text: "Reframe: Rewrite the UI copy.", sub: "Address vocabulary confusion", result: 'BEST_PATH', highlight: true });
                }
            } else if (type === 'risk_assessment') {
                // Pre-mortem Check
                renderRiskAssessment();
                return; // Handled specially
            }

            // Render Standard Options
            options.forEach(opt => {
                const btn = document.createElement('button');
                if (opt.result) {
                    // It's a final decision - Route to Risk Assessment first
                    btn.className = `apple-btn w-full text-left p-5 rounded-2xl ${opt.highlight ? 'bg-netflix/20 border-netflix/50' : 'bg-[#1C1C1E] border-white/10'} border hover:bg-white/10 transition-all flex justify-between items-center group`;
                    btn.innerHTML = `<div><span class="block text-white font-bold text-base mb-1">${opt.text}</span><span class="text-sm text-gray-400">${opt.sub}</span></div><i data-lucide="chevron-right" class="w-5 h-5 text-gray-500 group-hover:text-white transition-transform group-hover:translate-x-1"></i>`;
                    btn.onclick = () => { 
                        state.pendingDecision = opt.result; 
                        document.getElementById('choices-list').innerHTML=''; 
                        renderChoices('risk_assessment'); 
                    };
                } else {
                    // It's an investigation or scaffold choice
                    btn.className = `apple-btn w-full text-left p-5 rounded-2xl ${opt.highlight ? 'bg-white text-black' : 'bg-[#1C1C1E] border-white/10 text-white'} border hover:bg-white/20 transition-all flex justify-between items-center`;
                    
                    let innerContent = `<div><span class="block font-bold text-base mb-1">${opt.text}</span>`;
                    if (opt.sub) innerContent += `<span class="text-xs ${opt.highlight ? 'text-gray-700' : 'text-gray-400'}">${opt.sub}</span>`;
                    innerContent += `</div>`;
                    
                    if (opt.cost) {
                        innerContent += `<div class="flex items-center text-xs font-bold ${opt.highlight ? 'text-netflix' : 'text-gray-400'}"><i data-lucide="${opt.icon}" class="w-4 h-4 mr-2"></i> ${opt.cost}</div>`;
                    }
                    
                    btn.innerHTML = innerContent;
                    btn.onclick = opt.action;
                }
                choicesList.appendChild(btn);
            });
            lucide.createIcons();
            scrollToBottom();
        }

        function renderRiskAssessment() {
            const choicesList = document.getElementById('choices-list');
            choicesList.innerHTML = `
                <div class="system-prompt-bg p-5 rounded-2xl mb-2 text-center fade-in-up">
                    <p class="text-sm text-white font-bold mb-2"><i data-lucide="alert-triangle" class="w-5 h-5 inline text-yellow-500 mr-2 mb-1"></i> Pre-Mortem Risk Assessment</p>
                    <p class="text-xs text-gray-300">Identify the primary business risk of executing this directive before finalizing.</p>
                </div>
            `;
            
            // Map risks to the pending decision to ensure logic holds
            let risks = [];
            if (state.pendingDecision === 'BAD_DATA') {
                risks = [
                    { text: "Risk: We alienate power users and increase long-term churn.", correct: true },
                    { text: "Risk: We miss our short-term Q3 activation targets.", correct: false }
                ];
            } else if (state.pendingDecision === 'BAD_CREATIVE') {
                risks = [
                    { text: "Risk: We miss activation targets and cause executive panic.", correct: true },
                    { text: "Risk: The tool becomes too generic and loses value.", correct: false }
                ];
            } else if (state.pendingDecision === 'GOOD_PATH') {
                risks = [
                    { text: "Risk: We fragment the user base making support harder.", correct: true },
                    { text: "Risk: Both Sarah and Marcus will resign immediately.", correct: false }
                ];
            } else if (state.pendingDecision === 'BEST_PATH') {
                risks = [
                    { text: "Risk: Changing copy might not fix drop-off if it truly IS too complex.", correct: true },
                    { text: "Risk: Changing copy will anger the enterprise buyers.", correct: false }
                ];
            }

            risks.forEach(risk => {
                const btn = document.createElement('button');
                btn.className = "apple-btn w-full text-left p-5 rounded-xl bg-[#1C1C1E] border border-white/10 hover:bg-white/10 text-gray-300 hover:text-white text-sm font-medium transition-all fade-in-up";
                btn.innerText = risk.text;
                btn.onclick = () => {
                    if(risk.correct) state.scaffoldScore++;
                    document.getElementById('choices-list').innerHTML=''; 
                    resolveOutcome();
                };
                choicesList.appendChild(btn);
            });
            lucide.createIcons();
            scrollToBottom();
        }

        function resolveOutcome() {
            const resultKey = state.pendingDecision;
            const outcome = OUTCOMES[resultKey];
            
            let finalTrustImpact = outcome.trust;
            if (!state.ambiguityHeld && resultKey !== 'BAD_DATA') finalTrustImpact -= 10; 
            state.trust = Math.max(0, Math.min(100, state.trust + finalTrustImpact));
            updateHUD();

            let commandText = "";
            if (resultKey === 'BAD_DATA') commandText = "Team, we are cutting the configuration step to save activation targets. Make it happen.";
            if (resultKey === 'BAD_CREATIVE') commandText = "Team, we are keeping the step as-is. We cannot lose the enterprise value prop.";
            if (resultKey === 'GOOD_PATH') commandText = "Team, let's compromise. Add a 'Skip Setup' button to the flow.";
            if (resultKey === 'BEST_PATH') commandText = "Team, the issue isn't complexity, it's clarity. Marcus, rewrite the technical tooltips based on Sarah's log analysis.";
            
            renderBubble('user', commandText);
            scrollToBottom();

            setTimeout(() => {
                const container = document.getElementById('chat-container');
                const wrapper = document.createElement('div');
                wrapper.className = "fade-in-up mt-8";
                
                // Calibration Assessment based on Scaffold Score
                let calibrationText = "";
                let calColor = "";
                if (resultKey === 'BEST_PATH' && state.scaffoldScore >= 2) { calibrationText = "Masterful Calibration (High Critical Thinking)"; calColor="text-emerald-400"; }
                else if (resultKey === 'BEST_PATH') { calibrationText = "Lucky Guess (Skipped Root Cause Analysis)"; calColor="text-yellow-400"; }
                else if (state.scaffoldScore > 0) { calibrationText = "Analyzed correctly, but failed to execute."; calColor="text-yellow-400"; }
                else { calibrationText = "Blind Spot Detected (Low Analytical Rigor)"; calColor="text-red-400"; }

                wrapper.innerHTML = `
                    <div class="${outcome.bg} border ${outcome.border} rounded-3xl p-8 shadow-2xl relative overflow-hidden">
                        <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full blur-[80px] opacity-60 bg-current ${outcome.color}"></div>
                        <div class="flex justify-between items-start mb-6">
                            <span class="px-4 py-1.5 bg-black/60 rounded-full text-[10px] uppercase tracking-widest text-white border border-white/10 shadow-sm">Simulation Complete</span>
                            <div class="text-right">
                                <div class="text-[10px] uppercase tracking-widest text-gray-400 mb-1">Trust Impact</div>
                                <div class="text-3xl font-bold ${finalTrustImpact >= 0 ? 'text-emerald-400' : 'text-red-400'}">${finalTrustImpact >= 0 ? '+' : ''}${finalTrustImpact}%</div>
                            </div>
                        </div>
                        <h2 class="text-3xl font-bold text-white mb-3 tracking-tight">${outcome.title}</h2>
                        <p class="text-base text-gray-200 leading-relaxed mb-6 font-medium">${outcome.text}</p>
                        
                        <div class="bg-black/50 p-6 rounded-2xl border border-white/10 space-y-3 mt-4">
                            <h4 class="text-sm uppercase tracking-widest font-bold ${outcome.color} flex items-center"><i data-lucide="book-open" class="w-5 h-5 mr-2"></i> Executive Debrief</h4>
                            <p class="text-base text-gray-200 leading-relaxed">${outcome.debrief}</p>
                            <div class="mt-4 pt-4 border-t border-white/10">
                                <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-1">Analysis & Calibration Profile:</p>
                                <p class="text-sm font-bold ${calColor}">${calibrationText}</p>
                            </div>
                        </div>

                        <button onclick="location.reload()" class="w-full mt-8 bg-white text-black hover:bg-gray-200 font-bold py-4 rounded-xl transition-colors shadow-lg">Run New Scenario</button>
                    </div>
                `;
                container.appendChild(wrapper);
                lucide.createIcons();
                scrollToBottom();
            }, 1500);
        }

        window.onload = () => { initializeApp(); };
    </script>
</body>
</html>
